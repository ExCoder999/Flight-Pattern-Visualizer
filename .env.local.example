# Mapbox GL JS public token (get from https://account.mapbox.com)
NEXT_PUBLIC_MAPBOX_TOKEN=<your_mapbox_token>

# OpenSky Network (optional — uses mock data without credentials)
OPENSKY_USERNAME=<your_opensky_username>
OPENSKY_PASSWORD=<your_opensky_password>

# OpenWeatherMap OneCall API (get from https://openweathermap.org/api)
OPENWEATHERMAP_API_KEY=<your_openweathermap_key>

# Visual Crossing alternative weather API
VISUAL_CROSSING_API_KEY=<your_visual_crossing_key>
